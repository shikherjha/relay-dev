# Copy to .env and adjust as needed: cp .env.example .env
# These drive docker-compose.yml. Local dev defaults are fine to commit-free.

# Postgres
POSTGRES_USER=relay
POSTGRES_PASSWORD=relay
POSTGRES_DB=relay
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# Note: service-specific secrets (AWS, Bedrock, OpenAI, LifeLedger signer key)
# live in each repo's own .env (relay-api/.env, relay-ml/.env) and are NEVER committed.
